APP_NAME=工业机器人课程智能助教
APP_ENV=development
DATABASE_PATH=runtime/robot_tutor.db
KNOWLEDGE_ROOT=data/active
EVALUATION_ROOT=data/eval
ALARM_CODE_DATA_PATH=data/structured/alarm_codes_v1.json
KNOWLEDGE_POINT_DATA_PATH=data/structured/knowledge_points_v1.json
REPORTS_ROOT=reports
AUTO_INGEST=true
AUTO_INGEST_ALARM_CODES=true
AUTO_INGEST_KNOWLEDGE_POINTS=true
INGEST_BINARY_DOCUMENTS=false
RETRIEVAL_TOP_K=5
RETRIEVAL_STRATEGY=hybrid_rerank
RETRIEVAL_CANDIDATE_K=30
EMBEDDING_DIMENSION=128
RRF_BM25_WEIGHT=0.55
RRF_EMBEDDING_WEIGHT=0.45
EVIDENCE_THRESHOLD=0.55
AGENT_PROFILE=portable
# agentic-online / agentic-quality 才需要以下配置。密钥值不要写入本文件。
LLM_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY_ENV=OPENAI_API_KEY
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_STRUCTURED_OUTPUT_METHOD=json_schema
LLM_THINKING_MODE=
LLM_INPUT_COST_PER_MILLION=0
LLM_OUTPUT_COST_PER_MILLION=0
AGENTIC_FALLBACK_TO_PORTABLE=true
HF_CACHE_DIR=D:/hf_cache/hub
NEURAL_INDEX_CACHE_ROOT=runtime/neural_indexes
NEURAL_EMBEDDING_MODEL=BAAI/bge-small-zh
NEURAL_EMBEDDING_REVISION=1d2363c5de6ce9ba9c890c8e23a4c72dce540ca8
NEURAL_RERANKER_MODEL=BAAI/bge-reranker-base
NEURAL_RERANKER_REVISION=2cfc18c9415c912f9d8155881c133215df768a70
NEURAL_LOCAL_FILES_ONLY=true
NEURAL_DEVICE=cpu
NEURAL_BATCH_SIZE=16
NEURAL_RERANK_TOP_N=8
MAX_AGENT_STEPS=8
MAX_RETRIES=1
TOOL_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://localhost:8000
