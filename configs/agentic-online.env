# 受控 Agent 档：LangGraph + 真实 LLM 结构化决策 + 本地 RAG。
# 密钥只从 LLM_API_KEY_ENV 指向的环境变量读取。
AGENT_PROFILE=agentic-online
RETRIEVAL_STRATEGY=hybrid_rerank
RETRIEVAL_TOP_K=5
EVIDENCE_THRESHOLD=0.55
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY_ENV=DEEPSEEK_API_KEY
LLM_STRUCTURED_OUTPUT_METHOD=json_mode
LLM_THINKING_MODE=disabled
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_INPUT_COST_PER_MILLION=0.14
LLM_OUTPUT_COST_PER_MILLION=0.28
AGENTIC_FALLBACK_TO_PORTABLE=true
