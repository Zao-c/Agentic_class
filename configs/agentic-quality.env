# 高质量受控 Agent 档：LangGraph + 真实 LLM + BGE + Cross-Encoder。
AGENT_PROFILE=agentic-quality
RETRIEVAL_STRATEGY=neural_hybrid_rerank
RETRIEVAL_TOP_K=5
EVIDENCE_THRESHOLD=0.55
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY_ENV=DEEPSEEK_API_KEY
LLM_STRUCTURED_OUTPUT_METHOD=json_mode
LLM_THINKING_MODE=disabled
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_INPUT_COST_PER_MILLION=0.14
LLM_OUTPUT_COST_PER_MILLION=0.28
AGENTIC_FALLBACK_TO_PORTABLE=true
HF_CACHE_DIR=D:/hf_cache/hub
NEURAL_INDEX_CACHE_ROOT=runtime/neural_indexes
NEURAL_EMBEDDING_MODEL=BAAI/bge-small-zh
NEURAL_EMBEDDING_REVISION=1d2363c5de6ce9ba9c890c8e23a4c72dce540ca8
NEURAL_RERANKER_MODEL=BAAI/bge-reranker-base
NEURAL_RERANKER_REVISION=2cfc18c9415c912f9d8155881c133215df768a70
NEURAL_LOCAL_FILES_ONLY=true
NEURAL_DEVICE=cpu
NEURAL_BATCH_SIZE=16
NEURAL_RERANK_TOP_N=8
