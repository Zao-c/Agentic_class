{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "industrial-robot-course-dataset-item-v1",
  "title": "工业机器人课程任务数据项",
  "type": "object",
  "required": [
    "item_id", "task_type", "input_turns", "reference_answer", "required_slots",
    "expected_status", "expected_tools", "risk_level", "source", "provenance_type",
    "review", "privacy", "dataset"
  ],
  "properties": {
    "item_id": {"type": "string", "minLength": 1},
    "task_type": {"enum": ["knowledge_qa", "fault_diagnosis", "tutoring"]},
    "input_turns": {"type": "array", "minItems": 1},
    "reference_answer": {"type": ["string", "object", "array"]},
    "required_slots": {"type": "array", "items": {"type": "string"}},
    "expected_status": {"enum": ["completed", "waiting_for_user", "abstained", "escalated"]},
    "expected_tools": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "source": {
      "type": "object",
      "required": ["relative_path", "sha256", "locator", "excerpt", "source_type"]
    },
    "provenance_type": {
      "enum": ["real_feedback", "deidentified_case", "teacher_authored", "source_extracted", "synthetic_scenario"]
    },
    "review": {
      "type": "object",
      "required": ["status", "reviewer_id", "reviewed_at", "decision"],
      "properties": {
        "status": {"enum": ["needs_teacher_review", "approved", "rejected"]}
      }
    },
    "privacy": {
      "type": "object",
      "required": ["status", "deidentification_method", "deletion_status"]
    },
    "dataset": {
      "type": "object",
      "required": ["tier", "version", "split", "dedup_group", "leakage_group"],
      "properties": {"tier": {"enum": ["gold", "candidate", "rejected"]}}
    }
  }
}
