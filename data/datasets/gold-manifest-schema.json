{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "industrial-robot-course-gold-manifest-v1",
  "title": "冻结 Gold 数据集清单",
  "type": "object",
  "required": ["schema_version", "dataset_name", "dataset_version", "dataset_tier", "frozen_at", "immutable", "metric_eligibility", "item_count", "counts", "provenance", "artifact", "policy"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "dataset_tier": {"const": "gold"},
    "immutable": {"const": true},
    "metric_eligibility": {"const": true},
    "item_count": {"type": "integer", "minimum": 1},
    "provenance": {
      "type": "object",
      "required": ["candidate_sha256", "review_audit_sha256", "review_input_sha256", "review_batch_id"]
    },
    "artifact": {
      "type": "object",
      "required": ["file", "sha256", "hash_algorithm"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "hash_algorithm": {"const": "sha256"}
      }
    }
  }
}
